# Copy this file to `.env` (which is gitignored) and fill in your real values.
# `docker compose up` reads `.env` automatically.

# ── Stripe (sandbox / test mode) ──────────────────────────────────────
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Optional — override Checkout Session redirect URLs
# STRIPE_SUCCESS_URL=http://localhost:3000/payment/success?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel
